{
    "name": "bychoke/php8-masterclass-portfolio",
    "description": "Portafolio Masterclass PHP 8.5",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-gd": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "chillerlan/php-qrcode": "^6.0",
        "dompdf/dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "chillerlan/php-qrcode": true
        }
    }
}
